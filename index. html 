<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LibraryHub | Free Academic Management</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        /* --- CSS VARIABLES & THEMING --- */
        :root {
            --bg-body: #f4f7fe; --bg-sidebar: #ffffff; --bg-card: #ffffff;
            --text-main: #1e293b; --text-muted: #64748b; --accent: #2563eb;
            --accent-hover: #1d4ed8; --border: #e2e8f0; --danger: #ef4444;
            --success: #10b981; --warning: #f59e0b;
            --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
        }
        [data-theme="dark"] {
            --bg-body: #0b1437; --bg-sidebar: #111c44; --bg-card: #1b254b;
            --text-main: #ffffff; --text-muted: #a3aed1; --border: #2b3674;
            --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.5);
        }
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }
        body { background-color: var(--bg-body); color: var(--text-main); transition: 0.3s; overflow-x: hidden; }

        /* --- LAYOUT --- */
        .app-container { display: flex; min-height: 100vh; }
        .sidebar { width: 260px; background: var(--bg-sidebar); border-right: 1px solid var(--border); display: flex; flex-direction: column; padding: 1.5rem; position: fixed; height: 100vh; z-index: 100; }
        .logo { font-size: 1.5rem; font-weight: 700; color: var(--accent); margin-bottom: 2.5rem; display: flex; align-items: center; gap: 8px;}
        .logo span { color: var(--text-main); }
        .nav-section { font-size: 0.75rem; text-transform: uppercase; color: var(--text-muted); font-weight: 600; margin: 1.5rem 0 0.5rem 0; letter-spacing: 0.05em; }
        .nav-links { list-style: none; flex-grow: 1; }
        .nav-item { padding: 0.8rem 1rem; margin-bottom: 0.3rem; border-radius: 8px; cursor: pointer; color: var(--text-muted); font-weight: 500; transition: all 0.2s; display: flex; align-items: center; gap: 12px; }
        .nav-item:hover { background: rgba(37, 99, 235, 0.05); color: var(--accent); }
        .nav-item.active { background: var(--accent); color: white; box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3); }
        .hidden { display: none !important; }

        /* --- MAIN CONTENT --- */
        .main-content { margin-left: 260px; flex-grow: 1; padding: 2rem 3rem; width: calc(100% - 260px); }
        header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2.5rem; }
        .header-title { font-size: 1.75rem; font-weight: 700; }
        .header-controls { display: flex; align-items: center; gap: 1rem; }
        .role-selector { padding: 0.5rem 1rem; border-radius: 8px; border: 1px solid var(--border); background: var(--bg-card); color: var(--text-main); font-weight: 500; cursor: pointer; }
        
        /* --- COMPONENTS --- */
        .btn { padding: 0.6rem 1.2rem; border-radius: 8px; border: none; cursor: pointer; font-weight: 600; transition: 0.2s; font-size: 0.875rem; }
        .btn-primary { background: var(--accent); color: white; }
        .btn-primary:hover { background: var(--accent-hover); transform: translateY(-1px); }
        .btn-outline { background: transparent; border: 1px solid var(--border); color: var(--text-main); }
        .badge { padding: 0.25rem 0.6rem; border-radius: 99px; font-size: 0.75rem; font-weight: 600; }
        .badge-success { background: rgba(16, 185, 129, 0.1); color: var(--success); }
        .badge-warning { background: rgba(245, 158, 11, 0.1); color: var(--warning); }
        .badge-danger { background: rgba(239, 68, 68, 0.1); color: var(--danger); }
        .search-container { display: flex; gap: 1rem; margin-bottom: 1.5rem; }
        .search-input { flex-grow: 1; padding: 0.8rem 1.2rem; border-radius: 8px; border: 1px solid var(--border); background: var(--bg-card); color: var(--text-main); font-size: 0.95rem; box-shadow: var(--shadow); }

        /* GRIDS & CARDS */
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; margin-bottom: 2.5rem; }
        .stat-card { background: var(--bg-card); padding: 1.5rem; border-radius: 16px; border: 1px solid var(--border); box-shadow: var(--shadow); display: flex; flex-direction: column; gap: 0.5rem; }
        .stat-card h3 { font-size: 0.875rem; color: var(--text-muted); font-weight: 500; }
        .stat-card p { font-size: 1.8rem; font-weight: 700; color: var(--text-main); }

        .book-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1.5rem; }
        .book-card { background: var(--bg-card); border-radius: 16px; border: 1px solid var(--border); box-shadow: var(--shadow); overflow: hidden; transition: transform 0.2s; }
        .book-card:hover { transform: translateY(-4px); box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1); }
        .book-cover { height: 160px; background: linear-gradient(45deg, var(--border), var(--bg-body)); display: flex; align-items: center; justify-content: center; font-size: 2rem; color: var(--text-muted); }
        .book-info { padding: 1.2rem; }
        .book-title { font-weight: 600; font-size: 1.1rem; margin-bottom: 0.2rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .book-author { font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1rem; }
        .book-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--border); }

        /* TABLES */
        .table-card { background: var(--bg-card); border-radius: 16px; border: 1px solid var(--border); box-shadow: var(--shadow); overflow: hidden; }
        .table-header { padding: 1.2rem 1.5rem; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
        .table-header h3 { font-size: 1.1rem; font-weight: 600; }
        table { width: 100%; border-collapse: collapse; text-align: left; }
        th { padding: 1rem 1.5rem; border-bottom: 1px solid var(--border); font-size: 0.75rem; text-transform: uppercase; color: var(--text-muted); font-weight: 600; letter-spacing: 0.05em; background: rgba(0,0,0,0.01); }
        td { padding: 1rem 1.5rem; border-bottom: 1px solid var(--border); font-size: 0.9rem; vertical-align: middle; }

        /* NOTIFICATIONS */
        #toast-container { position: fixed; bottom: 20px; right: 20px; z-index: 1000; display: flex; flex-direction: column; gap: 10px; }
        .toast { background: var(--bg-card); border-left: 4px solid var(--accent); color: var(--text-main); padding: 1rem 1.5rem; border-radius: 8px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.2); animation: slideIn 0.3s ease forwards; }
        @keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
    </style>
</head>
<body>

<div class="app-container">
    <aside class="sidebar">
        <div class="logo">📘 <span>LibraryHub</span></div>
        <ul class="nav-links">
            <div class="nav-section">Main Menu</div>
            <li class="nav-item active" data-target="dashboard">📊 <span>Dashboard</span></li>
            <li class="nav-item" data-target="books">📚 <span>Library Catalog</span></li>
            
            <div class="nav-section">My Account</div>
            <li class="nav-item" data-target="borrows">📖 <span>Borrow History</span></li>
            <li class="nav-item" data-target="activity">📋 <span>My Activity</span></li>
            
            <div id="teacher-menu" class="hidden">
                <div class="nav-section">Academic</div>
                <li class="nav-item" data-target="student-logs">🔍 <span>Student Logs</span></li>
            </div>
            <div id="admin-menu" class="hidden">
                <div class="nav-section">Administration</div>
                <li class="nav-item" data-target="admin-books">⚙️ <span>Inventory</span></li>
                <button class="btn btn-outline" onclick="seedFirebaseData()" style="width: 100%; margin-top: 20px; font-size: 0.75rem;">+ Seed Database</button>
            </div>
        </ul>
    </aside>

    <main class="main-content">
        <header>
            <h1 class="header-title" id="page-title">Dashboard</h1>
            <div class="header-controls">
                <button class="btn btn-outline" onclick="toggleTheme()">🌓</button>
                <select class="role-selector" id="role-switcher" onchange="switchRole(this.value)">
                    <option value="student">🎓 View as Student</option>
                    <option value="teacher">📝 View as Teacher</option>
                    <option value="admin">🛡️ View as Admin</option>
                </select>
                <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--accent); color: white; display: flex; align-items: center; justify-content: center; font-weight: bold;">
                    <span id="user-initial">S</span>
                </div>
            </div>
        </header>

        <div id="view-dashboard" class="view-section">
            <div class="stats-grid" id="dashboard-stats">Loading stats...</div>
            <div class="table-card">
                <div class="table-header"><h3>Recent Platform Activity</h3></div>
                <table>
                    <thead><tr><th>User</th><th>Action</th><th>Book</th><th>Time</th></tr></thead>
                    <tbody id="dash-activity-body"><tr><td colspan="4">Loading...</td></tr></tbody>
                </table>
            </div>
        </div>

        <div id="view-books" class="view-section hidden">
            <div class="search-container">
                <input type="text" class="search-input" id="book-search" placeholder="Search by title..." oninput="renderBooks()">
            </div>
            <div class="book-grid" id="book-grid-container">Loading catalog...</div>
        </div>

        <div id="view-borrows" class="view-section hidden">
            <div class="table-card">
                <div class="table-header"><h3>My Borrow History</h3></div>
                <table>
                    <thead><tr><th>Book Title</th><th>Date</th><th>Status</th></tr></thead>
                    <tbody id="borrows-body"><tr><td colspan="3">Loading...</td></tr></tbody>
                </table>
            </div>
        </div>

        <div id="view-activity" class="view-section hidden">
            <div class="table-card">
                <div class="table-header"><h3>My Personal Logs</h3></div>
                <table>
                    <thead><tr><th>Action</th><th>Details</th><th>Time</th></tr></thead>
                    <tbody id="my-logs-body"><tr><td colspan="3">Loading...</td></tr></tbody>
                </table>
            </div>
        </div>

        <div id="view-student-logs" class="view-section hidden">
            <div class="table-card">
                <div class="table-header"><h3>Global Student Logs</h3></div>
                <table>
                    <thead><tr><th>Student</th><th>Action</th><th>Book</th><th>Date</th></tr></thead>
                    <tbody id="all-student-logs"><tr><td colspan="4">Loading...</td></tr></tbody>
                </table>
            </div>
        </div>

        <div id="view-admin-books" class="view-section hidden">
             <div class="table-card">
                <div class="table-header"><h3>Inventory Management</h3></div>
                <table>
                    <thead><tr><th>Title</th><th>Category</th><th>Stock</th></tr></thead>
                    <tbody id="admin-inventory-body"><tr><td colspan="3">Loading...</td></tr></tbody>
                </table>
            </div>
        </div>
    </main>
</div>

<div id="toast-container"></div>

<script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/12.10.0/firebase-app.js";
    import { getFirestore, collection, getDocs, addDoc, doc, updateDoc, onSnapshot, query, where, orderBy, limit } from "https://www.gstatic.com/firebasejs/12.10.0/firebase-firestore.js";

    // YOUR ACTUAL CONFIGURATION
    const firebaseConfig = {
        apiKey: "AIzaSyAQYfWb81B89vmT0_ypZF3VNEhTtDV0hoA",
        authDomain: "libraryhub-3e6be.firebaseapp.com",
        projectId: "libraryhub-3e6be",
        storageBucket: "libraryhub-3e6be.firebasestorage.app",
        messagingSenderId: "843399614230",
        appId: "1:843399614230:web:b8fca579c633f350908a37",
        measurementId: "G-PZKX7RX0SE"
    };

    const app = initializeApp(firebaseConfig);
    const db = getFirestore(app);

    // --- STATE ---
    window.DB = {
        currentUser: { name: "Sam Student", id: "S101", role: "student" },
        books: [],
        borrows: [],
        logs: []
    };

    // --- REAL-TIME LISTENERS ---
    function initDatabaseListeners() {
        // Listen to Books
        onSnapshot(collection(db, "books"), (snapshot) => {
            window.DB.books = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
            renderBooks();
            renderDashboard();
            renderAdminBooks();
        });

        // Listen to Borrows
        onSnapshot(collection(db, "borrows"), (snapshot) => {
            window.DB.borrows = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
            renderBorrows();
            renderDashboard();
        });

        // Listen to Logs
        onSnapshot(query(collection(db, "logs"), orderBy("timestamp", "desc"), limit(20)), (snapshot) => {
            window.DB.logs = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
            renderDashboard();
            renderMyLogs();
            renderStudentLogs();
        });
    }

    // --- RENDER FUNCTIONS ---
    window.renderDashboard = function() {
        const statsArea = document.getElementById('dashboard-stats');
        if (window.DB.currentUser.role === 'admin') {
            statsArea.innerHTML = `
                <div class="stat-card"><h3>Total Books Cataloged</h3><p>${window.DB.books.length}</p></div>
                <div class="stat-card"><h3>Active Borrows System-wide</h3><p>${window.DB.borrows.filter(b => b.status === 'Active').length}</p></div>
            `;
        } else {
            const myActive = window.DB.borrows.filter(b => b.userId === window.DB.currentUser.id && b.status === 'Active').length;
            statsArea.innerHTML = `
                <div class="stat-card"><h3>Currently Borrowed</h3><p>${myActive}</p></div>
                <div class="stat-card"><h3>Account Status</h3><p style="color:var(--success); font-size:1.2rem; margin-top:10px;">Good Standing</p></div>
            `;
        }

        document.getElementById('dash-activity-body').innerHTML = window.DB.logs.slice(0, 4).map(log => `
            <tr>
                <td><strong>${log.user}</strong></td>
                <td><span class="badge ${log.action === 'Returned' ? 'badge-success' : 'badge-warning'}">${log.action}</span></td>
                <td>${log.details}</td>
                <td style="color:var(--text-muted)">${new Date(log.timestamp).toLocaleDateString()}</td>
            </tr>
        `).join('');
    }

    window.renderBooks = function() {
        const queryVal = (document.getElementById('book-search') ? document.getElementById('book-search').value.toLowerCase() : '');
        const filtered = window.DB.books.filter(b => b.title.toLowerCase().includes(queryVal));
        
        document.getElementById('book-grid-container').innerHTML = filtered.map(book => `
            <div class="book-card">
                <div class="book-cover">📚</div>
                <div class="book-info">
                    <div class="badge ${book.stock > 0 ? 'badge-success' : 'badge-danger'}" style="margin-bottom:0.5rem; display:inline-block">
                        ${book.stock > 0 ? `Available (${book.stock})` : 'Unavailable'}
                    </div>
                    <div class="book-title" title="${book.title}">${book.title}</div>
                    <div class="book-author">${book.author} • ${book.category}</div>
                    <div class="book-footer">
                        <button class="btn btn-primary" style="width:100%" onclick="processBorrow('${book.id}', ${book.stock}, '${book.title}')" ${book.stock === 0 ? 'disabled' : ''}>
                            ${book.stock > 0 ? 'Borrow Book' : 'Out of Stock'}
                        </button>
                    </div>
                </div>
            </div>
        `).join('') || "No books found.";
    }

    window.renderBorrows = function() {
        const myBorrows = window.DB.borrows.filter(t => t.userId === window.DB.currentUser.id);
        document.getElementById('borrows-body').innerHTML = myBorrows.map(t => `
            <tr>
                <td><strong>${t.book}</strong></td>
                <td>${new Date(t.timestamp).toLocaleDateString()}</td>
                <td><span class="badge ${t.status === 'Returned' ? 'badge-success' : 'badge-warning'}">${t.status}</span></td>
            </tr>
        `).join('') || "<tr><td colspan='3'>No borrowing history.</td></tr>";
    }

    window.renderMyLogs = function() {
        const myLogs = window.DB.logs.filter(l => l.userId === window.DB.currentUser.id);
        document.getElementById('my-logs-body').innerHTML = myLogs.map(l => `
            <tr><td><span class="badge badge-success">${l.action}</span></td><td>${l.details}</td><td>${new Date(l.timestamp).toLocaleDateString()}</td></tr>
        `).join('') || "<tr><td colspan='3'>No activity yet.</td></tr>";
    }

    window.renderStudentLogs = function() {
        document.getElementById('all-student-logs').innerHTML = window.DB.logs.map(l => `
            <tr>
                <td><strong>${l.user}</strong> <br><span style="font-size:0.75rem; color:var(--text-muted)">${l.userId}</span></td>
                <td><span class="badge badge-warning">${l.action}</span></td>
                <td>${l.details}</td>
                <td>${new Date(l.timestamp).toLocaleDateString()}</td>
            </tr>
        `).join('');
    }

    window.renderAdminBooks = function() {
        document.getElementById('admin-inventory-body').innerHTML = window.DB.books.map(b => `
            <tr>
                <td><strong>${b.title}</strong><br><span style="font-size:0.75rem; color:var(--text-muted)">${b.author}</span></td>
                <td>${b.category}</td>
                <td>${b.stock} Copies</td>
            </tr>
        `).join('');
    }

    // --- ACTIONS (WRITING TO FIREBASE) ---
    window.processBorrow = async function(bookId, currentStock, bookTitle) {
        if(currentStock > 0) {
            try {
                // 1. Update Stock in Firebase
                const bookRef = doc(db, "books", bookId);
                await updateDoc(bookRef, { stock: currentStock - 1 });

                // 2. Add Borrow Record
                await addDoc(collection(db, "borrows"), {
                    userId: window.DB.currentUser.id,
                    book: bookTitle,
                    status: "Active",
                    timestamp: Date.now()
                });

                // 3. Add Activity Log
                await addDoc(collection(db, "logs"), {
                    userId: window.DB.currentUser.id,
                    user: window.DB.currentUser.name,
                    action: "Borrowed",
                    details: bookTitle,
                    timestamp: Date.now()
                });

                window.showToast(`Successfully borrowed ${bookTitle}!`);
            } catch (e) {
                console.error("Error borrowing book: ", e);
                window.showToast("Database error. Could not borrow book.");
            }
     